{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "subpanel",
  "main": "worker.mjs",
  "compatibility_date": "2026-05-14",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
